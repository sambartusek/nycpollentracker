# this Gemfile replicates the way Github renders the site. to serve the site locally (e.g. in order to test changes
# before pushing to main), run these commands:
#
# bundle install
# bundle exec jekyll serve
#
# and navigate to http://localhost:4000 in your browser.
# you will need to install jekyll - https://jekyllrb.com/docs/installation/ 

source "https://rubygems.org"
gem "github-pages", group: :jekyll_plugins
